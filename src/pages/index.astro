              <img src="/media/images/deltasoft.webp" alt="Deltasoft AI" height="60px">
              <div class="my-auto"><span class="link-secondary" data-bs-toggle="tooltip" data-bs-placement="bottom" data-bs-title="Coming soon!">Deltasoft AI</span></div>
