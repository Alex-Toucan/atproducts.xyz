<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Seto 🌸</title>
  <link rel="shortcut icon" type="image/png" href="/media/favicon/favicon.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/media/favicon/apple-touch-icon.png">
  <link rel="icon" type="image/png" href="/media/favicon/favicon.png">
  <link rel="icon" type="image/png" href="/media/favicon/android-chrome-192x192.png">
  <link rel="icon" type="image/png" sizes="32x32" href="/media/favicon/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/media/favicon/favicon-16x16.png">
  <link rel="mask-icon" href="/media/favicon/safari-pinned-tab.svg" color="#5bbad5">
  <meta property="og:title" content="For Seto 🌸">
  <meta property="og:image" content="/media/favicon/iconembed.png">
  <meta name="theme-color" content="#ff3a76">
  <meta name="msapplication-TileColor" content="#da532c">
  <link rel="manifest" href="/media/favicon/site.webmanifest">
  <!-- Bootstrap 5 -->
  <link href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.3/css/bootstrap.min.css" rel="stylesheet" />
  <!-- Google Fonts: Cormorant Garamond (display) + DM Sans (body) -->
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,600;1,300;1,600&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
  <!-- jQuery + jQuery UI -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jqueryui/1.13.3/jquery-ui.min.js"></script>

  <style>
    /* ── TOKENS ── */
    :root {
      --wine:   #7B2D3E;   /* deep rose — primary */
      --blush:  #F0CDD3;   /* soft pink — surface tint */
      --petal:  #FAE8EC;   /* lightest pink — bg wash */
      --cream:  #FDFAF8;   /* near-white warm base */
      --ink:    #1A0F12;   /* near-black warm */
      --muted:  #9A7480;   /* desaturated rose-gray */
      --gold:   #B8935A;   /* warm accent */
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }

    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--cream);
      color: var(--ink);
      overflow: hidden;        /* one slide at a time */
      height: 100svh;
    }

    /* ── PETAL CANVAS ── */
    #petal-canvas {
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 0;
    }

    /* ── PROGRESS STRIPE ── */
    #prog {
      position: fixed;
      top: 0; left: 0;
      height: 2px;
      background: var(--wine);
      z-index: 200;
      transition: width .5s cubic-bezier(.4,0,.2,1);
    }

    /* ── DOT NAV ── */
    #dots {
      position: fixed;
      bottom: 1.5rem;
      left: 50%;
      transform: translateX(-50%);
      display: flex;
      gap: .55rem;
      z-index: 200;
    }
    .dot {
      width: 7px; height: 7px;
      border-radius: 50%;
      background: var(--blush);
      cursor: pointer;
      transition: background .3s, transform .3s;
    }
    .dot.on { background: var(--wine); transform: scale(1.5); }

    /* ── SLIDE WRAPPER ── */
    .slide {
      position: fixed;
      inset: 0;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 2.5rem 1.5rem 5rem;
      opacity: 0;
      pointer-events: none;
      z-index: 1;
      transition: opacity .5s ease;
      overflow-y: auto;
    }
    .slide.active {
      opacity: 1;
      pointer-events: all;
    }

    /* ── TYPOGRAPHY ── */
    .display {
      font-family: 'Cormorant Garamond', serif;
      font-weight: 300;
      line-height: 1.08;
      color: var(--ink);
    }
    .display em { color: var(--wine); font-style: italic; }
    .eyebrow {
      font-size: .65rem;
      letter-spacing: .3em;
      text-transform: uppercase;
      color: var(--muted);
      font-weight: 500;
    }
    .body-text {
      font-size: 1rem;
      line-height: 1.75;
      color: var(--muted);
    }

    /* ── BUTTONS ── */
    .btn-wine {
      display: inline-block;
      background: var(--wine);
      color: #fff;
      border: none;
      border-radius: 3px;
      padding: .7rem 2rem;
      font-family: 'DM Sans', sans-serif;
      font-size: .85rem;
      font-weight: 500;
      letter-spacing: .08em;
      text-transform: uppercase;
      cursor: pointer;
      transition: background .2s, transform .15s, box-shadow .2s;
      box-shadow: 0 3px 14px rgba(123,45,62,.25);
    }
    .btn-wine:hover {
      background: #5e2130;
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(123,45,62,.35);
    }
    .btn-ghost {
      display: inline-block;
      background: transparent;
      color: var(--muted);
      border: 1.5px solid var(--blush);
      border-radius: 3px;
      padding: .65rem 1.5rem;
      font-size: .8rem;
      letter-spacing: .06em;
      text-transform: uppercase;
      cursor: pointer;
      transition: border-color .2s, color .2s;
    }
    .btn-ghost:hover { border-color: var(--wine); color: var(--wine); }

    /* ── SLIDE BACKGROUNDS ── */
    #s1 { background: linear-gradient(150deg, #fff2f4 0%, var(--cream) 65%); }
    #s2 { background: var(--cream); }
    #s3 { background: var(--cream); }
    #s4 { background: linear-gradient(150deg, #fff2f4 0%, var(--cream) 65%); }
    #s5 { background: linear-gradient(150deg, #fff2f4 0%, var(--cream) 65%); }
    #s6 { background: var(--cream); }
    #s7 { background: linear-gradient(150deg, #fff2f4 0%, var(--cream) 65%); }

    /* ── SLIDE 1: HERO ── */
    .hero-rose {
      font-size: 3.2rem;
      display: block;
      margin-bottom: 1.2rem;
      animation: sway 4s ease-in-out infinite;
    }
    @keyframes sway {
      0%,100% { transform: rotate(-6deg) translateY(0); }
      50%      { transform: rotate(6deg) translateY(-10px); }
    }
    #s1 .display { font-size: clamp(3rem, 10vw, 6.5rem); text-align: center; }

    /* ── SLIDE 2: REASONS ── */
    .reason-row {
      display: flex;
      align-items: flex-start;
      gap: 1rem;
      padding: .85rem 0;
      border-bottom: 1px solid var(--blush);
      opacity: 0;
      transform: translateX(-28px);
      transition: opacity .45s ease, transform .45s ease;
    }
    .reason-row.in { opacity: 1; transform: none; }
    .reason-row:last-child { border-bottom: none; }
    .r-mark {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.6rem;
      font-weight: 300;
      color: var(--wine);
      line-height: 1;
      min-width: 1.8rem;
    }
    .r-text { font-size: .97rem; line-height: 1.7; color: var(--ink); }

    /* ── SLIDE 3: TIMELINE ── */
    .tl { max-width: 440px; width: 100%; padding-left: 2rem; position: relative; }
    .tl::before {
      content: '';
      position: absolute;
      left: 5px; top: 0; bottom: 0;
      width: 1.5px;
      background: var(--blush);
    }
    .tl-row {
      position: relative;
      margin-bottom: 1.75rem;
      opacity: 0;
      transform: translateY(16px);
      transition: opacity .45s, transform .45s;
    }
    .tl-row.in { opacity: 1; transform: none; }
    .tl-row::before {
      content: '';
      position: absolute;
      left: -1.73rem;
      top: .4rem;
      width: 10px; height: 10px;
      border-radius: 50%;
      background: var(--wine);
      border: 2px solid var(--cream);
      outline: 1.5px solid var(--wine);
    }
    .tl-label {
      font-size: .62rem;
      letter-spacing: .22em;
      text-transform: uppercase;
      color: var(--muted);
    }
    .tl-head {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.25rem;
      font-weight: 600;
      margin: .1rem 0 .25rem;
    }
    .tl-body { font-size: .88rem; color: var(--muted); line-height: 1.65; }

    /* ── SLIDE 5: THE QUESTION ── */
    .q-card {
      background: #fff;
      border-radius: 4px;
      padding: 2.2rem 1.8rem;
      max-width: 460px;
      width: 100%;
      box-shadow: 0 6px 32px rgba(123,45,62,.1);
      border-top: 3px solid var(--wine);
    }
    .q-meta {
      font-size: .62rem;
      letter-spacing: .25em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: .4rem;
    }
    .q-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(1.5rem, 5vw, 2.1rem);
      font-weight: 600;
      line-height: 1.2;
      margin-bottom: 1.6rem;
    }
    .choice {
      display: flex;
      align-items: center;
      gap: .85rem;
      padding: .75rem 1rem;
      border: 1.5px solid var(--blush);
      border-radius: 3px;
      margin-bottom: .65rem;
      cursor: pointer;
      transition: border-color .2s, background .2s, transform .15s;
      user-select: none;
    }
    .choice:hover { border-color: var(--wine); background: var(--petal); transform: translateX(3px); }
    .choice.picked { border-color: var(--wine); background: var(--petal); }
    .choice.picked .c-bubble { background: var(--wine); color: #fff; }
    .c-bubble {
      width: 26px; height: 26px;
      border-radius: 50%;
      background: var(--blush);
      color: var(--wine);
      font-size: .7rem;
      font-weight: 700;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }
    .c-text { font-size: .93rem; }
    #no-btn { position: relative; }   /* "No" button runs away */

    /* ── SLIDE 6: YES ── */
    .yes-icon {
      font-size: 4rem;
      display: block;
      margin-bottom: 1rem;
    }
    #s6 .display { font-size: clamp(2.5rem,9vw,5.5rem); text-align: center; }

    /* ── SLIDE 7: NETLIFY FORM — "Official" ── */
    .official-card {
      background: #fff;
      border-radius: 4px;
      padding: 2.2rem 1.8rem;
      max-width: 440px;
      width: 100%;
      box-shadow: 0 6px 32px rgba(123,45,62,.1);
      border-top: 3px solid var(--gold);
    }
    .official-card label {
      display: block;
      font-size: .62rem;
      letter-spacing: .22em;
      text-transform: uppercase;
      color: var(--muted);
      font-weight: 500;
      margin-bottom: .3rem;
    }
    .official-card input,
    .official-card textarea {
      width: 100%;
      padding: .65rem .9rem;
      border: 1.5px solid var(--blush);
      border-radius: 3px;
      font-family: 'DM Sans', sans-serif;
      font-size: .9rem;
      color: var(--ink);
      background: #fff;
      transition: border-color .2s;
      margin-bottom: 1.1rem;
    }
    .official-card input:focus,
    .official-card textarea:focus {
      outline: none;
      border-color: var(--wine);
    }
    .official-card textarea { resize: vertical; min-height: 72px; }

    /* ── SLIDE 7: FINAL ── */
    #s7 { background: linear-gradient(150deg,#fff2f4,var(--cream)); }
    #s7 .display { font-size: clamp(2.2rem,8vw,5rem); text-align: center; }

    /* ── NAV ROW ── */
    .nav-row {
      display: flex;
      align-items: center;
      gap: .85rem;
      margin-top: 2rem;
      justify-content: center;
    }

    @media (prefers-reduced-motion: reduce) {
      * { animation: none !important; transition: none !important; }
    }

  </style>
</head>
<body>

<canvas id="petal-canvas"></canvas>
<div id="prog"></div>
<div id="dots"></div>

<!-- ═══════════════════════════════════════
     SLIDE 1 · INTRO
═══════════════════════════════════════ -->
<div class="slide active" id="s1">
  <span class="hero-rose">🌹</span>
  <p class="eyebrow mb-2">A message for you</p>
  <h1 class="display mb-3">Hey,<br><em>Seto.</em></h1>
  <p class="body-text text-center" style="max-width:30ch">
    We met seven days ago.<br>I already made you a whole website.
  </p>
  <div class="nav-row">
    <button class="btn-wine" onclick="go(2)">Open it &rarr;</button>
  </div>
</div>

<!-- ═══════════════════════════════════════
     SLIDE 2 · REASONS
═══════════════════════════════════════ -->
<div class="slide" id="s2">
  <div style="max-width:480px;width:100%">
    <p class="eyebrow mb-1">Why you — in just 7 days</p>
    <h2 class="display mb-4" style="font-size:clamp(2rem,6vw,3.5rem)">Things I already know<br>I can't stop thinking about</h2>

    <div class="reason-row"><span class="r-mark">✦</span><span class="r-text">The way you laugh — like you mean it every time.</span></div>
    <div class="reason-row"><span class="r-mark">✦</span><span class="r-text">Talking to you feels easy. Like I've known you way longer than a week.</span></div>
    <div class="reason-row"><span class="r-mark">✦</span><span class="r-text">How kind you are. I noticed it fast.</span></div>
    <div class="reason-row"><span class="r-mark">✦</span><span class="r-text">Seven days in and I'm already thinking about you all the time.</span></div>
    <div class="reason-row"><span class="r-mark">✦</span><span class="r-text">I just really like you, Clarisa. I had to say it.</span></div>

    <div class="nav-row">
      <button class="btn-ghost" onclick="go(1)">&larr;</button>
      <button class="btn-wine" onclick="go(3)">There's more &rarr;</button>
    </div>
  </div>
</div>

<!-- ═══════════════════════════════════════
     SLIDE 3 · TIMELINE
═══════════════════════════════════════ -->
<div class="slide" id="s3">
  <div style="max-width:480px;width:100%">
    <p class="eyebrow mb-1 text-center">June 16 → June 23</p>
    <h2 class="display mb-4 text-center" style="font-size:clamp(1.8rem,5vw,3rem)">Seven days.<br><em>That's all it took.</em></h2>

    <div class="tl">
      <div class="tl-row">
        <div class="tl-label">June 16, 2026</div>
        <div class="tl-head">We met.</div>
        <div class="tl-body">Seven days ago. That's all it took.</div>
      </div>
      <div class="tl-row">
        <div class="tl-label">June 16 → now</div>
        <div class="tl-head">I started noticing everything.</div>
        <div class="tl-body">The way you talk, the way you think. A week felt like enough to know.</div>
      </div>
      <div class="tl-row">
        <div class="tl-label">Somewhere this week</div>
        <div class="tl-head">I knew I liked you.</div>
        <div class="tl-body">I know it's only been a week. But I know how I feel.</div>
      </div>
      <div class="tl-row">
        <div class="tl-label">June 23rd, 2026 — today</div>
        <div class="tl-head">I'm saying it.</div>
        <div class="tl-body">One more slide. 🌹</div>
      </div>
    </div>

    <div class="nav-row">
      <button class="btn-ghost" onclick="go(2)">&larr;</button>
      <button class="btn-wine" onclick="go(4)">The question &rarr;</button>
    </div>
  </div>
</div>

<!-- ═══════════════════════════════════════
     SLIDE 4 · THE QUESTION
═══════════════════════════════════════ -->
<div class="slide" id="s4">
  <div class="q-card">
    <p class="q-meta">One question</p>
    <h2 class="q-title">Clarisa Anabela Rivas —<br>will you be my girlfriend? 🌹</h2>

    <div id="choices">
      <div class="choice" onclick="pick(this,'yes')">
        <div class="c-bubble">A</div>
        <div class="c-text">Yes 🥰</div>
      </div>
      <div class="choice" onclick="pick(this,'yes2')">
        <div class="c-bubble">B</div>
        <div class="c-text">Obviously yes 😭</div>
      </div>
      <div class="choice" onclick="pick(this,'yes3')">
        <div class="c-bubble">C</div>
        <div class="c-text">...yes (she says quietly) 🙈</div>
      </div>
      <div class="choice" id="no-btn" onclick="noRun(this)">
        <div class="c-bubble">D</div>
        <div class="c-text">No</div>
      </div>
    </div>

    <div id="submit-area" style="display:none;margin-top:1.25rem;text-align:center">
      <button class="btn-wine" onclick="submitAnswer()">Submit ✓</button>
    </div>

    <div class="nav-row" style="justify-content:flex-start;margin-top:1.25rem">
      <button class="btn-ghost" onclick="go(3)">&larr; Back</button>
    </div>
  </div>
</div>

<!-- ═══════════════════════════════════════
     SLIDE 5 · YES REACTION
═══════════════════════════════════════ -->
<div class="slide" id="s5">
  <span class="yes-icon" id="yesIcon">🎉</span>
  <h2 class="display mb-3"><em>She said yes.</em></h2>
  <p class="body-text text-center" style="max-width:32ch;margin:0 auto 2rem">
    We've known each other a week.<br>
    You just made it the best week.<br>
    One tiny last step.
  </p>
  <button class="btn-wine" onclick="go(6)">Make it official &rarr;</button>
</div>

<!-- ═══════════════════════════════════════
     SLIDE 6 · OFFICIAL FORM (Netlify)
═══════════════════════════════════════ -->
<div class="slide" id="s6">
  <div style="max-width:440px;width:100%;text-align:center">
    <p class="eyebrow mb-1">Make it official</p>
    <h2 class="display mb-4" style="font-size:clamp(1.8rem,5vw,2.8rem)">Sign your name.<br><em>It's real now.</em></h2>

    <form
      name="girlfriend-yes"
      method="POST"
      data-netlify="true"
      netlify-honeypot="bot-field"
      id="official-form"
      class="official-card text-start"
    >
      <input type="hidden" name="form-name" value="girlfriend-yes" />
      <p style="display:none"><label>Don't fill: <input name="bot-field" /></label></p>

      <label for="f-name">Your full name</label>
      <input
        type="text"
        id="f-name"
        name="name"
        placeholder="Clarisa Anabela Rivas"
        required
      />

      <label for="f-msg">Anything you want to say to him? 🥺</label>
      <textarea
        id="f-msg"
        name="message"
        placeholder="(optional — but it would mean a lot)"
      ></textarea>

      <button type="submit" class="btn-wine w-100">Make it official 🌹</button>
    </form>

    <div class="nav-row">
      <button class="btn-ghost" onclick="go(5)">&larr;</button>
    </div>
  </div>
</div>

<!-- ═══════════════════════════════════════
     SLIDE 7 · END
═══════════════════════════════════════ -->
<div class="slide" id="s7">
  <div style="font-size:3rem;margin-bottom:1rem">🌹</div>
  <h2 class="display mb-3"><em>It's official.</em></h2>
  <p class="body-text text-center" style="max-width:34ch;margin:0 auto 1rem">
    You're my girlfriend now, Seto.<br>I'm not taking that back.
  </p>
  <p style="font-size:.62rem;letter-spacing:.25em;text-transform:uppercase;color:var(--blush);margin-top:2rem">
    For Clarisa Anabela Rivas &nbsp;·&nbsp; June 16 → forever
  </p>
</div>

<!-- ═══════════════════════════════════════
     SCRIPTS
═══════════════════════════════════════ -->
<script>
/* ── SLIDE STATE ── */
const TOTAL = 7;
let cur = 1;
const ids = n => document.getElementById('s' + n);

// Build dots
const dotWrap = document.getElementById('dots');
for (let i = 1; i <= TOTAL; i++) {
  const d = document.createElement('div');
  d.className = 'dot' + (i === 1 ? ' on' : '');
  d.addEventListener('click', () => window.go(i));
  dotWrap.appendChild(d);
}

window.go = function go(n) {
  if (n < 1 || n > TOTAL) return;
  const from = ids(cur);
  const to   = ids(n);

  $(from).animate({ opacity: 0 }, 300, function() {
    $(from).removeClass('active').css('opacity','');
    $(to).css('opacity', 0).addClass('active').animate({ opacity: 1 }, 350);
    cur = n;
    updateChrome();
    onEnter(n);
    window.scrollTo(0, 0);
  });
}

window.updateChrome = function updateChrome() {
  // progress
  document.getElementById('prog').style.width =
    ((cur - 1) / (TOTAL - 1) * 100) + '%';
  // dots
  document.querySelectorAll('.dot').forEach((d, i) => {
    d.classList.toggle('on', i + 1 === cur);
  });
}

/* ── SLIDE ENTER HOOKS ── */
window.onEnter = function onEnter(n) {
  if (n === 2) {
    document.querySelectorAll('.reason-row').forEach((el, i) => {
      el.classList.remove('in');
      setTimeout(() => el.classList.add('in'), 80 + i * 100);
    });
  }
  if (n === 3) {
    document.querySelectorAll('.tl-row').forEach((el, i) => {
      el.classList.remove('in');
      setTimeout(() => el.classList.add('in'), 150 + i * 170);
    });
  }
  if (n === 5) {
    setTimeout(() => {
      $('#yesIcon').effect('bounce', { times: 5, distance: 22 }, 800);
    }, 300);
  }
}

/* ── QUESTION LOGIC ── */
let picked = null;

window.pick = function pick(el, val) {
  document.querySelectorAll('.choice').forEach(c => c.classList.remove('picked'));
  el.classList.add('picked');
  picked = val;
  document.getElementById('submit-area').style.display = 'block';
}

window.submitAnswer = function submitAnswer() {
  if (!picked) return;
  go(5);
}

// "No" button runs away
let noMoves = 0;
window.noRun = function noRun(btn) {
  noMoves++;
  const card = btn.closest('.q-card');
  const maxX = card.offsetWidth - btn.offsetWidth - 16;
  const rx = Math.max(0, Math.floor(Math.random() * maxX));
  const ry = (Math.random() > .5 ? 1 : -1) * (20 + Math.random() * 40);

  btn.style.position = 'relative';
  btn.style.transition = 'left .25s, top .25s';
  btn.style.left = rx + 'px';
  btn.style.top  = ry + 'px';
  btn.style.opacity = '.35';

  const taunts = [
    "nope, try again 😄",
    "wrong answer 😇",
    "not an option 🙈",
    "still no 😤",
    "seriously? 😂"
  ];
  btn.querySelector('.c-text').textContent =
    taunts[Math.min(noMoves - 1, taunts.length - 1)];

  setTimeout(() => {
    btn.style.left = '';
    btn.style.top = '';
    btn.style.opacity = '1';
  }, 1100);
}

/* ── NETLIFY FORM ── */
document.getElementById('official-form').addEventListener('submit', function(e) {
  e.preventDefault();
  const body = new FormData(this);
  fetch('/', { method: 'POST', body })
    .finally(() => go(7));
});

/* ── FALLING PETALS ── */
(function() {
  const cvs = document.getElementById('petal-canvas');
  const ctx  = cvs.getContext('2d');
  let W, H, pts = [];

  function resize() {
    W = cvs.width  = window.innerWidth;
    H = cvs.height = window.innerHeight;
  }
  window.addEventListener('resize', resize);
  resize();

  const COLS = ['#F0CDD3','#FAE8EC','#f5b8c2','#fde0e4'];

  function spawn(full) {
    return {
      x: Math.random() * W,
      y: full ? Math.random() * H : -18,
      r: 4 + Math.random() * 7,
      col: COLS[Math.floor(Math.random() * COLS.length)],
      vx: (Math.random() - .5) * .5,
      vy: .4 + Math.random() * .7,
      rot: Math.random() * Math.PI * 2,
      vr: (Math.random() - .5) * .035,
      a: .35 + Math.random() * .45,
    };
  }

  for (let i = 0; i < 20; i++) pts.push(spawn(true));

  function frame() {
    ctx.clearRect(0, 0, W, H);
    pts.forEach(p => {
      ctx.save();
      ctx.globalAlpha = p.a;
      ctx.translate(p.x, p.y);
      ctx.rotate(p.rot);
      ctx.beginPath();
      ctx.ellipse(0, 0, p.r, p.r * .52, 0, 0, Math.PI * 2);
      ctx.fillStyle = p.col;
      ctx.fill();
      ctx.restore();
      p.x += p.vx; p.y += p.vy; p.rot += p.vr;
      if (p.y > H + 20) Object.assign(p, spawn(false));
    });
    requestAnimationFrame(frame);
  }
  frame();

  setInterval(() => { if (pts.length < 28) pts.push(spawn(false)); }, 2000);
})();

/* ── KEYBOARD NAV ── */
document.addEventListener('keydown', e => {
  if (e.key === 'ArrowRight' || e.key === 'ArrowDown') go(cur + 1);
  if (e.key === 'ArrowLeft'  || e.key === 'ArrowUp')   go(cur - 1);
});

/* ── INIT ── */
updateChrome();
