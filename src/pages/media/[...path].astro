---
import fs from "node:fs";
import path from "node:path";

export async function getStaticPaths() {
  const root = path.join(process.cwd(), "public/media");

  function walk(dir, prefix = "") {
    const entries = fs.readdirSync(dir, { withFileTypes: true });
    let paths = [];

    paths.push({ params: { path: prefix } });

    for (const entry of entries) {
      if (entry.isDirectory()) {
        const sub = prefix ? `${prefix}/${entry.name}` : entry.name;
        paths = paths.concat(walk(path.join(dir, entry.name), sub));
      }
    }

    return paths;
  }

  return walk(root);
}

const reqPath = typeof Astro.params.path === "string" ? Astro.params.path : "";

const dir = path.join(process.cwd(), "public/media", reqPath);

const indexFile = path.join(dir, "index.json");

let items = [];
if (fs.existsSync(indexFile)) {
  items = JSON.parse(fs.readFileSync(indexFile, "utf8"));
}

items = items.sort((a, b) => {
  if (a.type === "directory" && b.type !== "directory") return -1;
  if (a.type !== "directory" && b.type === "directory") return 1;
  return a.name.localeCompare(b.name);
});

const parent = reqPath.split("/").slice(0, -1).join("/");
const parentUrl = parent ? `/media/${parent}` : `/media`;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Index of /media/{reqPath}</title>
    <link rel="shortcut icon" type="image/png" href="/media/favicon/favicon.png">
    <link rel="apple-touch-icon" sizes="180x180" href="/media/favicon/apple-touch-icon.png">
    <link rel="icon" type="image/png" href="/media/favicon/favicon.png">
    <link rel="icon" type="image/png" href="/media/favicon/android-chrome-192x192.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/media/favicon/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/media/favicon/favicon-16x16.png">
    <link rel="mask-icon" href="/media/favicon/safari-pinned-tab.svg" color="#5bbad5">
    <meta property="og:image" content="/media/favicon/iconembed.png">
    <meta name="twitter:image" content="/media/favicon/iconembed.png">
    <link rel="manifest" href="/media/favicon/site.webmanifest">
    <meta charset="UTF-8">
    <meta name="msapplication-TileColor" content="#da532c">
    <meta name="title" content={`Index of /media/${reqPath}`}>
    <meta name="description" content={`Index of /media/${reqPath}`}>
    <meta name="twitter:card" content="summary">
    <meta name="twitter:site" content="@ATProductsLLC">
    <meta name="twitter:creator" content="@ATProductsLLC">
    <meta name="twitter:title" content={`Index of /media/${reqPath}`}>
    <meta name="twitter:description" content={`Index of /media/${reqPath}`}>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta property="og:title" content={`Index of /media/${reqPath}`}>
    <meta property="og:description" content={`Index of /media/${reqPath}`}>
    <meta property="og:site_name" content="AT Products LLC">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <style>
      body {
        background: #111;
        color: #ddd;
        font-family: monospace;
        padding: 2rem;
      }
      a {
        color: #4da3ff;
        text-decoration: none;
      }
      a:hover {
        text-decoration: underline;
      }
      table {
        width: 100%;
        border-collapse: collapse;
      }
      th, td {
        padding: 0.5rem;
        border-bottom: 1px solid #333;
        text-align: left;
      }
      tr:hover {
        background: #1a1a1a;
      }
      .copyright {
        margin-top: 2rem;
        font-size: 1.17em;
        text-align: center;
      }
    </style>
  </head>

  <body>
    <h1>Index of /media/{reqPath}</h1>

    {reqPath && (
      <p>
        <a href={parentUrl}>⬅ Parent Directory</a>
      </p>
    )}

    <table>
      <thead>
        <tr>
          <th>Name</th>
          <th>Size</th>
          <th>Modified</th>
        </tr>
      </thead>
      <tbody>
        {items.map(item => {
          const url = `/media/${item.path}`;
          return (
            <tr>
              <td>
                <a href={url}>
                  {item.type === "directory" ? "📁" : "📄"} {item.name}
                </a>
              </td>
              <td>{item.size ?? "-"}</td>
              <td>{item.mtime}</td>
            </tr>
          );
        })}
      </tbody>
    </table>
    <div class="copyright">&reg; <script is:inline src="/static/year.js"></script> <a href="https://atproducts.xyz">AT Products LLC</a></div>
  </body>
</html>
