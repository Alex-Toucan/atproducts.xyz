---
import DefaultBody from '../layouts/DefaultBody.astro';
import Hero from '../components/Hero.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import FirstPaidCard from '../components/secondary/FirstPaidCard.astro';
import SecondPaidCard from '../components/secondary/SecondPaidCard.astro';
import BackToTop from '../components/BackToTop.astro';

import '../styles/paid.css'
---

<DefaultBody title="Paid Services" heroid="web" description="Get stuff done with AT Products!" keywords="AT Products, Ethical Hacking Society, The Script Community, AT Products LLC, ATproducts" author="Alex Toucan">
<div id="page">
  <Navbar />
  <div id="main-content">
    <Hero id="web" title="Paid Services" description="Get stuff done with AT Products LLC; our digital services will help you create your own services!" 
      buttons={[
        { href: "/paidterms", text: "Paid Services & Website Creation Policies and Terms", type: "secondary" },
      ]},
    />
    <main id="paid" class="text-center container">
      <figure class="my-4">
        <p class="fs-lg mb-2">"Where innovation meets quality. Experience the difference with our cutting-edge technology, impeccable craftsmanship, and unwavering commitment to customer satisfaction. Elevate your expectations and unlock a world of possibilities with AT Products LLC."</p>
        <figcaption class="blockquote-footer fs-sm fg-secondary">
          <cite title="Quote Source"> JSman255 from <a href="/codinghome">CodingHome</a>. </cite>
        </figcaption>
      </figure>
      <div class="md:d-flex d-grid gap-3 flex-wrap mb-3">
        <div class="md:col">
          <FirstPaidCard 
            title="Website Design" 
            id="website-design"
            price="$20-500*" 
            description="Your website can have the most modern stuff on the market with HTML5 &amp; CSS3, Bootstrap v5, responsive layout, and will be compatible with most major browsers with the Website Design package! (Estimates will be provided)" 
            additionalContent="<div class='accordion w-100 text-start md:d-none mb-3' id='defintionsAccordion-1'><details class='accordion-item'><summary class='accordion-header'>What does any of this stuff mean? <svg class='accordion-icon' xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16' fill='none' stroke='currentColor' stroke-linecap='round' stroke-linejoin='round'><path d='m2 5 6 6 6-6'/></svg></summary><div id='defintions-1' class='accordion-body'><div class='d-grid gap-3'><div class='d-flex'><img src='/media/images/HTML.webp' alt='HTML5' width='60px' height='60px' class='d-block md:d-inline mb-2 md:mb-0 me-2 object-fit-contain'><div class='col my-auto'><strong>HTML5</strong> is the most recent version of HTML. More information about it can be found <a href='https://www.graycelltech.com/why-use-html-5/' target='_blank' rel='noopener noreferrer'>here</a>.</div></div><div class='d-flex'><img src='/media/images/CSS.webp' alt='CSS3' width='60px' height='60px' class='d-block md:d-inline mb-2 md:mb-0 me-2 object-fit-contain'><div class='col my-auto'><strong>CSS3</strong> is the most recent version of CSS. More information about it can be found <a href='https://www.geeksforgeeks.org/advantage-of-css3-over-css/'>here</a>.</div></div><div class='d-flex'><img src='/media/images/bootstrap.webp' alt='Bootstrap' width='60px' height='60px' class='d-block md:d-inline mb-2 md:mb-0 me-2 object-fit-contain'><div class='col my-auto'><strong>Bootstrap</strong> is a popular choice in CSS frameworks, as it brings a modern design to websites. Their official site is <a href='https://getbootstrap.com/'>here</a>.</div></div><div><strong>Responsive layout</strong> is a layout that is compatible with any screen, from phones, to tablets, laptops, desktops, etc.</div><div><strong>Compatible with most major browsers</strong>, note this is more including Google Chrome, Microsoft Edge, Mozilla Firefox, Opera, or any browser that contains the modern HTML, CSS, and JS standards. We no longer support Internet Explorer.</div></div></div></details></div>"
            buttonHref="/contact/" 
            buttonText="Contact us" 
            footerText="* Prices may be raised dependent on the requested project, these are not guaranteed prices." 
          />
        </div>
        <div class="md:col">
          <FirstPaidCard 
            title="Website Hosting"
            id="website-hosting" 
            price="$1-75*<small class='text-body-secondary fw-light'>/week or month</small>" 
            secondaryPrice="<b>$1-50/week or month</b> with the &quot;Website Design&quot; package." 
            description="Keep your website up with our services! This package includes security certificate renewals and updates to your Content Security Policy." 
            additionalContent="<div class='accordion w-100 text-start md:d-none mb-3' id='defintionsAccordion-2'><details class='accordion-item'><summary class='accordion-header'>What does any of this stuff mean? <svg class='accordion-icon' xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16' fill='none' stroke='currentColor' stroke-linecap='round' stroke-linejoin='round'><path d='m2 5 6 6 6-6'/></svg></summary><div id='defintions-2' class='accordion-body'><div class='d-grid gap-3'><div><strong>Security certificate renewals</strong>, to keep your website secure as possible with HTTPS.</div><div><strong>Content security policy</strong>, to block out which sources you do not want to be on your website. You can learn more about it <a href='https://developer.mozilla.org/en-US/docs/Web/HTTP/CSP'>here.</a></FirstPaidCard></div></div></div></details></div>"
            buttonHref="/contact/" 
            buttonText="Contact us" 
            footerText="* These are not guaranteed prices." 
          />
        </div>
        <SecondPaidCard 
          title="Other Services"
          id="other-services"
          description="These are other services that we offer as secondary services."
          footerText="* These are not guaranteed prices."
          buttonHref="/contact/" 
          buttonText="Contact us" 
        >
          <div slot="paid-card-content" class="d-grid gap-3">
            <div class="p-3 rounded border bg-3 md:col h-100">
              <h5 class="fw-bold mb-2">Website Maintenance</h5>
              <p class="mb-1 text-body">
                $10 - $150 (varies)*
              </p>
              <p class="mb-0 text-body-secondary">
                Keep your site up-to-date, fix bugs, and ensure everything runs smoothly.  
                No primary package is required before purchasing this service.
              </p>
            </div>
            <div class="p-3 rounded border bg-3 md:col h-100">
              <h5 class="fw-bold mb-2">Email Creation</h5>
              <p class="mb-1 text-body">
                $20 (No DNS Setup) • $30 (DNS Setup)
              </p>
              <p class="mb-0 text-body-secondary">
                We create up to 5 users for your domain using Zoho Mail.  
                DNS access is required (usually in your registrar’s settings).
              </p>
            </div>
          </div>
        </SecondPaidCard>
        <div class="accordion w-100 text-start d-none md:d-block" id="defintionsAccordion-3">
          <details class="accordion-item">
            <summary class="accordion-header">
              What does any of this stuff mean?
              <svg class="accordion-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><path d="m2 5 6 6 6-6"/></svg>
            </summary>
            <div id="defintions-3" class="accordion-body">
              <div class="d-grid gap-3">
                <div class="d-flex">
                  <img src="/media/images/HTML.webp" alt="HTML5" width="60px" height="60px" class="d-block md:d-inline mb-2 md:mb-0 me-2 object-fit-contain">
                  <div class="col my-auto">
                    <strong>HTML5</strong> is the most recent version of HTML. More information about it can be found <a href="https://www.graycelltech.com/why-use-html-5/" target="_blank" rel="noopener noreferrer">here</a>.
                  </div>
                </div>
                <div class="d-flex">
                  <img src="/media/images/CSS.webp" alt="CSS3" width="60px" height="60px" class="d-block md:d-inline mb-2 md:mb-0 me-2 object-fit-contain">
                  <div class="col my-auto">
                    <strong>CSS3</strong> is the most recent version of CSS. More information about it can be found <a href="https://www.geeksforgeeks.org/advantage-of-css3-over-css/">here</a>.
                  </div>
                </div>
                <div class="d-flex">
                  <img src="/media/images/bootstrap.webp" alt="Bootstrap" width="60px" height="60px" class="d-block md:d-inline mb-2 md:mb-0 me-2 object-fit-contain">
                  <div class="col my-auto">
                    <strong>Bootstrap</strong> is a popular choice in CSS frameworks, as it brings a modern design to websites. Their official site is <a href="https://getbootstrap.com/">here</a>.
                  </div>
                </div>
                <div>
                  <strong>Responsive layout</strong> is a layout that is compatible with any screen, from phones, to tablets, laptops, desktops, etc.
                </div>
                <div>
                  <strong>Compatible with most major browsers</strong>, note this is more including Google Chrome, Microsoft Edge, Mozilla Firefox, Opera, or any browser that contains the modern HTML, CSS, and JS standards. We no longer support Internet Explorer.
                </div>
                <div>
                  <strong>Security certificate renewals</strong>, to keep your website secure as possible with HTTPS.
                </div>
                <div>
                  <strong>Content security policy</strong>, to block out which sources you do not want to be on your website. You can learn more about it <a href="https://developer.mozilla.org/en-US/docs/Web/HTTP/CSP">here.</a>
                </div>
              </div>
            </div>
          </details>
        </div>
        <SecondPaidCard 
          id="clients"
          title="Clients"
          description="These are our clients who have requested a site, and got a site!"
        >
          <div slot="paid-card-content" class="d-grid gap-2">
            <div class="card rounded-4 bg-3 shadow-sm overflow-hidden border d-flex md:flex-row flex-column">
              <div class="md:col-5">
                <img 
                  src="/media/images/Screenshot_25-1-2026_191158_stephanystreasures.com.jpeg" 
                  alt="Stephany's Treasures website preview"
                  class="w-100 h-100 object-fit-cover client-img"
                >
              </div>
              <div class="md:col-7 d-flex flex-column p-4">
                <div class="d-flex flex-wrap flex-column align-items-center gap-3">
                  <img src="/media/images/short-step.webp" width ="15%" alt="Stephany's Treasures' icon" class="short-img">
                  <h3 class="fw-bold mb-2">Stephany's Treasures</h3>
                </div>
                <p class="text-body py-1 mb-3">
                  An antique, jewelry, and home décor store with a modern, responsive website built by AT Products LLC.
                </p>
                <a 
                  href="http://stephanystreasures.com" 
                  target="_blank" 
                  rel="noopener noreferrer" 
                  class="btn-solid theme-primary mt-auto w-100"
                >
                  Visit Website
                </a>
              </div>
            </div>
            <div class="card rounded-4 bg-3 shadow-sm overflow-hidden border d-flex md:flex-row flex-column">
              <div class="md:col-5">
                <img 
                  src="/media/images/Screenshot_25-2-2026_9023_carboncurrency.netlify.app.jpeg" 
                  alt="Carbon Currency website preview"
                  class="w-100 h-100 object-fit-cover client-img"
                >
              </div>
              <div class="md:col-7 d-flex flex-column p-4">
                <div class="d-flex flex-wrap flex-column align-items-center gap-3">
                  <img src="/media/images/group.png" width="30%" alt="Carbon Currency's icon" class="card-img rounded-4">
                  <h3 class="fw-bold mb-2">Carbon Currency</h3>
                </div>
                <p class="text-body py-1 mb-3">
                  A Washington‑state–based rap duo who needed a website built by AT Products LLC.
                </p>
                <a 
                  href="https://carboncurrency.netlify.app/" 
                  target="_blank" 
                  rel="noopener noreferrer" 
                  class="btn-solid theme-primary mt-auto w-100"
                >
                  Visit Website
                </a>
              </div>
            </div>
          </div>
        </SecondPaidCard>
        <SecondPaidCard 
          title="Donation Box" 
          id="donation-box"
          description="If you would like to donate without buying our packages, you can do so here!"
        >
          <div slot="paid-card-content">
            <div class="p-3 d-flex flex-column flex-wrap gap-4">
              <a class="btn btn-lg btn-solid theme-primary w-75 md:w-50 mx-auto" href="https://pay.atproducts.xyz/donate">Donate Here</a>
              <a class="btn btn-lg btn-solid theme-primary w-75 md:w-50 mx-auto" href="https://ads.atproducts.xyz">Watch Advertisements</a>
              <div><b>CashApp:</b> $ATProductsLLC </div>
            </div>
          </div>
        </SecondPaidCard>
      </div>
      <p> For any questions regarding our paid services, please <a href="/contact/">contact us</a>. <a href="/paidterms">Terms may apply</a>. </p>
    </main>
    <Footer />
  </div>
  <BackToTop />
</div>
</DefaultBody>
