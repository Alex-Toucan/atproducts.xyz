---
import DefaultBody from '../../layouts/DefaultBody.astro';
import Navbar    from '../../components/Navbar.astro';
import Footer    from '../../components/Footer.astro';
import BackToTop from '../../components/BackToTop.astro';
---

<DefaultBody title="Success - Contact Form" description="We got your submission successfully!" author="Alex Toucan">
<div id="page">
      <div id="main-content">
            <Navbar />
                <main id="success" class="container text-center pt-4 pb-1">
                  <i class="bi bi-check-lg contact-check fg-secondary"></i>
                  <p class="mt-3 fg-secondary fs-2xl">Thanks for your submission, we'll reach out to you soon.</p>
                  <a class="icon-link icon-link-hover index-link pb-5" href="/">Return to the Index page
                  <i class="bi bi-arrow-right h-100"></i></a>
            <hr class="mx-2">
                  <p class="fs-sm fg-secondary">Reloading this page may resubmit what you previously submitted.</p>
                </main>
            <Footer />
      </div>
      <BackToTop />
</div>
</DefaultBody>
