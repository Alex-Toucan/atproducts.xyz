---
const {
  id,
  title,
  titleClasses,
  description,
  errorButton,
  buttons,
  imageSrc,
  imageWidth,
  imageClasses,
  imageAlt,
  marginBottom,
  icons,
  dropdownItems,
  container,
  size,
  htmlContent
} = Astro.props;

const flexSize = size ? size : 'md';
---

<div id="intro" class={`hero hero-${id} text-center ${marginBottom === 'false' ? '' : 'mb-3'}`} data-bs-theme="dark">
  <div class="hero-back h-100 p-3 position-relative">
    <div class="hero-filter w-100 align-items-center d-flex justify-content-center my-466 text-center">
      <div class="text-white">
        { htmlContent ? (
          <Fragment set:html={htmlContent} />
        ) : (
          <div class={`${container === 'true' ? 'container' : ''}`}>
            <div>
              {imageSrc && (
                <img src={imageSrc} width={imageWidth} alt="icon" class={imageClasses} alt={`${imageAlt ? imageAlt : 'icon'}`} />
              )}
              {title && (
                <h1 class={`fs-4xl md:fs-5xl fw-bold ${imageSrc ? 'mt-4 md:mt-0 d-block md:d-inline align-middle' : ''} ${titleClasses ? titleClasses : ''}`}>{title}</h1>
              )}
            </div>
            <p class="fs-lg m-3 mb-0 fg-2" set:html={description}></p>
            <div class="mx-auto justify-content-between container mt-3" id="links">
              <div class={`d-${flexSize}-flex d-grid gap-2`}>
                {errorButton && (
                  <Fragment set:html={errorButton} />
                )}
                {buttons && (
                  buttons.map(({ href, text, type }, index) => (
                    <a href={href} class={`btn-solid theme-${type} md:col`}>{text}</a>
                  ))
                )}
                {dropdownItems && (
                  <div class="dropdown md:col">
                    <button aria-expanded="false" data-bs-toggle="menu" type="button" class="btn-solid theme-secondary dropdown-toggle w-100">
                      Navigation
                    </button>
                    <ul class="menu w-100 white-space-normal">
                      {dropdownItems.map(({ navigationDesc, navigationLink }, index) => (
                        <li>
                          <a class="menu-item" href={navigationLink}>{navigationDesc}</a>
                        </li>
                      ))}
                    </ul>
                  </div>
                )}
              </div>
              {icons && (
                <div class="mt-2 p-1 d-flex justify-content-center gap-3 bg-1 rounded-2" id="icons">
                  {icons && icons.map(({ icon, desc, href }, index) => (
                    <a href={href} aria-label={desc} target="_blank" rel="noopener noreferrer" class="link-hero" data-bs-toggle="tooltip" data-bs-placement="bottom" data-bs-title={desc}>
                      <i class={`bi bi-${icon}`}></i>
                    </a>
                  ))}
                </div>
              )}
            </div>
          </div>
        )}
      </div>
    </div>
  </div>
</div>
