---
const { breadcrumb, breadcrumbcontent, link, pageTitle } = Astro.props;
---

<a href="#main-content" class="visually-hidden-focusable btn-solid theme-primary position-fixed m-2 hero-filter skip-content" title="Skip to main content">Skip to main content</a>

<header class="main-navbar fixed-top">

  <nav class="navbar lg:navbar-expand fg-2">
    <div class="container-fluid">
      <a class="navbar-brand" href="/">
        <img src="/media/images/longblack.webp" height="45px" alt="AT Products LLC" class="headerimg">
      </a>
      <button class="btn-icon navbar-toggler" type="button" data-bs-toggle="offcanvas" data-bs-target="#navbarLeftDrawer" aria-controls="navbarLeftDrawer" aria-expanded="false" aria-label="Toggle navigation">
        <svg class="navbar-toggler-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round"><path d="M1 3.5h14M1 8h14M1 12.5h14"/></svg>
      </button>
      <div class="offcanvas offcanvas-start" tabindex="-1" id="navbarLeftDrawer" aria-labelledby="navbarLeftDrawerLabel">
        <div class="offcanvas-header">
          <h5 class="offcanvas-title" id="navbarLeftDrawerLabel">
            <img src="/media/images/longblack.webp" height="45px" alt="AT Products LLC" class="headerimg">
          </h5>
          <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" width="20" height="20" fill="none">
        <path fill="currentcolor" d="M12 0a4 4 0 0 1 4 4v8a4 4 0 0 1-4 4H4a4 4 0 0 1-4-4V4a4 4 0 0 1 4-4zm-.646 4.646a.5.5 0 0 0-.707 0L8 7.293 5.354 4.646a.5.5 0 1 0-.708.708L7.293 8l-2.647 2.647a.5.5 0 1 0 .708.707L8 8.707l2.647 2.646a.5.5 0 1 0 .707-.707L8.707 8l2.646-2.646a.5.5 0 0 0 0-.708z"/>
      </svg>
      </button>
        </div>
        <div class="offcanvas-body">
          <ul class="navbar-nav me-auto mb-2 md:mb-0">
            <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
            <li class="nav-item dropdown">
              <a class="nav-link dropdown-toggle" href="javascript:void(0)" role="button" data-bs-toggle="menu" data-bs-container="body" aria-expanded="false">
                Products
                <i class="bi bi-sm bi-chevron-expand" aria-hidden="true"></i>
              </a>
              <ul class="menu">
                <li><a class="menu-item text-wrap-auto" href="/paid">Paid Services</a></li>
                <li class="submenu">
                  <button class="menu-item" type="button">Web Projects</button>
                  <ul class="menu">
                    <li><a class="menu-item text-wrap-auto" href="/flash">Flash Documentation</a></li>
                    <li><a class="menu-item text-wrap-auto" href="/mdickie">MDickie Projects</a></li>
                    <li><a class="menu-item text-wrap-auto" href="https://games.atproducts.xyz/">AT's Unblocked Games</a></li>
                    <li><a class="menu-item text-wrap-auto" href="/roms">AT's ROM Games</a></li>
                  </ul>
                </li>                
                <li><a class="menu-item text-wrap-auto" href="/stories">Stories</a></li>
                <li><a class="menu-item text-wrap-auto" href="/sms">SMS Bomb</a></li>
                <li><a class="menu-item text-wrap-auto" href="/minefalls">Mine Falls</a></li>
                <li class="submenu">
                  <button class="menu-item" type="button">Pynx Projects</button>
                  <ul class="menu">
                    <li><a class="menu-item text-wrap-auto" href="/pynx/radiumos">RadiumOS</a></li>
                    <li><a class="menu-item text-wrap-auto" href="/pynx/ezpkgm">ezpkgm</a></li>
                    <li><a class="menu-item text-wrap-auto" href="/pynx/pson">PSON</a></li>
                    <li><a class="menu-item text-wrap-auto" href="/pynx/bxpp">BxPP</a></li>
                    <li><a class="menu-item text-wrap-auto" href="/pynx/fentamini">FentaMini</a></li>
                    <li><a class="menu-item text-wrap-auto" href="/pynx/inferno">Inferno</a></li>
                  </ul>
                </li>                
              </ul>
            </li>
            <li class="nav-item dropdown">
              <a class="nav-link dropdown-toggle" href="javascript:void(0)" role="button" data-bs-toggle="menu" data-bs-container="body" aria-expanded="false">
                Departments
                <i class="bi bi-sm bi-chevron-expand" aria-hidden="true"></i>
              </a>
              <ul class="menu">
                <li><a class="menu-item text-wrap-auto" href="https://beta-testing.atproducts.xyz/">Department of Beta Testing</a></li>
                <li><a class="menu-item text-wrap-auto" href="https://portfolio.atproducts.xyz/#toucanempire">The Toucan Empire</a></li>
                <li><a class="menu-item text-wrap-auto" href="https://portfolio.atproducts.xyz/#atpweather">ATPWeather</a></li>
              </ul>
            </li>
            <li class="nav-item dropdown">
              <a class="nav-link dropdown-toggle" href="javascript:void(0)" role="button" data-bs-toggle="menu" data-bs-container="body" aria-expanded="false">
                Communities
                <i class="bi bi-sm bi-chevron-expand" aria-hidden="true"></i>
              </a>
              <ul class="menu">
                <li><a class="menu-item text-wrap-auto" href="/ehs">Ethical Hacking Society</a></li>
                <li><a class="menu-item text-wrap-auto" href="/script">The Script Community</a></li>
                <li><a class="menu-item text-wrap-auto" href="/codinghome">CodingHome</a></li>
                <li><a class="menu-item text-wrap-auto" href="/noodle">Noodle Hackerspace</a></li>
              </ul>
            </li>
            <li class="nav-item dropdown">
              <a class="nav-link dropdown-toggle" href="javascript:void(0)" role="button" data-bs-toggle="menu" data-bs-container="body" aria-expanded="false">
                Documentation
                <i class="bi bi-sm bi-chevron-expand" aria-hidden="true"></i>
              </a>
              <ul class="menu">
                <li><a class="menu-item text-wrap-auto" href="/terms">Terms of Service</a></li>
                <li><a class="menu-item text-wrap-auto" href="/discord">Discord Rules</a></li>
                <li><a class="menu-item text-wrap-auto" href="/privacy">Privacy Policy</a></li>
                <li class="submenu">
                  <button class="menu-item" type="button">Other Policies</button>
                  <ul class="menu">
                    <li><a class="menu-item text-wrap-auto" href="/paidterms">Paid Services & Website Creation Policies and Terms</a></li>
                    <li><a class="menu-item text-wrap-auto" href="/titleiiandvii">Title II & VII Policy</a></li>
                  </ul>
                </li>                
                <li><a class="menu-item text-wrap-auto" href="/licenses">Licenses</a></li>
              </ul>
            </li>
          </ul>

          {breadcrumb && (
            <ol class="navbar-nav breadcrumb m-0 flex-row d-block lg:d-none mt-4">
              <li class="breadcrumb-item"><a href="/">Home</a></li>
              <li class="breadcrumb-divider">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 8 16" width="6" height="12"><path d="M2 2l4 6-4 6" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </li>
              {link && link.map(({ name, href, dropdown }, index) => (
                <li class={`breadcrumb-item ${dropdown && breadcrumbcontent ? 'dropdown' : ''}`} key={index}>
                  <a href={href} class={dropdown && breadcrumbcontent ? 'dropdown-toggle' : ''} data-bs-toggle={dropdown && breadcrumbcontent ? 'dropdown' : undefined} aria-expanded="false">{name}</a>
                  {dropdown && breadcrumbcontent && (
                    <ul class="menu dropdown-story" data-bs-popper="static" aria-label="Dropdown">
                      {breadcrumbcontent.map(({ name, href }, index) => (
                        <li key={index}><a class="menu-item text-wrap-auto" href={href}>{name}</a></li>
                      ))}
                    </ul>
                  )}
                </li>
                <li class="breadcrumb-divider">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 8 16" width="6" height="12"><path d="M2 2l4 6-4 6" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </li>
              ))}
              <li class="breadcrumb-item active" aria-current="page">{pageTitle}</li>
            </ol>
          )}

          <div class="navbar-nav custom-group justify-content-start lg:ms-auto nav-tab-link mb-0 color-changer">
            <div class="custom-group-item p-0 dropdown dropdown-section color-dropdown">
              <a class="dropdown-toggle custom-group-item-action color-button d-block" href="javascript:void(0)" role="button" data-bs-toggle="menu" data-bs-auto-close="outside" id="bd-theme">
                <span class="theme-icon-active"><i class="bi bi-sun-fill me-2 lg:me-0"></i></span>
                <span class="lg:d-none" id="bd-theme-text">Change theme</span>
                <i class="bi bi-sm bi-chevron-expand ms-1 lg:ms-2" aria-hidden="true"></i>
              </a>
              <div class="menu p-0" data-bs-display="static" data-bs-popper="static">
                <div class="custom-group">
                  <a class="menu-item text-wrap-auto" href="javascript:void(0)" data-bs-theme-value="light">
                    <i class="bi bi-sun-fill me-2"></i> Light
                  </a>
                  <a class="menu-item text-wrap-auto" href="javascript:void(0)" data-bs-theme-value="dark">
                    <i class="bi bi-moon-stars-fill me-2"></i> Dark
                  </a>
                  <a class="menu-item text-wrap-auto" href="javascript:void(0)" data-bs-theme-value="auto">
                    <i class="bi bi-circle-half me-2"></i> Auto
                  </a>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </nav>

  {breadcrumb && (
    <nav class="navbar pt-0 d-none lg:d-block">
      <div class="container-fluid">
        <ol class="navbar-nav breadcrumb m-0 flex-row">
          <li class="breadcrumb-item"><a href="/">Home</a></li>
          <li class="breadcrumb-divider">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 8 16" width="6" height="12"><path d="M2 2l4 6-4 6" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </li>
          {link && link.map(({ name, href, dropdown }, index) => (
            <li class={`breadcrumb-item ${dropdown && breadcrumbcontent ? 'dropdown' : ''}`} key={index}>
              <a href={href} class={dropdown && breadcrumbcontent ? 'dropdown-toggle' : ''} data-bs-toggle={dropdown && breadcrumbcontent ? 'dropdown' : undefined} aria-expanded="false">{name}</a>
              {dropdown && breadcrumbcontent && (
                <ul class="menu dropdown-story" data-bs-popper="static" aria-label="Dropdown">
                  {breadcrumbcontent.map(({ name, href }, index) => (
                    <li key={index}><a class="menu-item text-wrap-auto" href={href}>{name}</a></li>
                  ))}
                </ul>
              )}
            </li>
            <li class="breadcrumb-divider">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 8 16" width="6" height="12"><path d="M2 2l4 6-4 6" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </li>
          ))}
          <li class="breadcrumb-item active" aria-current="page">{pageTitle}</li>
        </ol>
      </div>
    </nav>
  )}
</header>

<noscript>
  <div class="alert alert-dark mb-0" role="alert">
  <strong>It seems like you don't have JavaScript enabled!</strong> You will need JavaScript for color modes, accordions, scrollspies, tab panes, dropdowns, popovers, and more! We do not have fallbacks, so please enable JavaScript or <a href="https://github.com/Alex-Toucan/atproducts.xyz">view the source code to read the information</a>.
</noscript>